# Database
MONGO_URI=mongodb://localhost:27017/ecom_admin
REDIS_URL=redis://localhost:6379

# JWT (RS256 key pair)
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Timezone
BUSINESS_TIMEZONE=UTC

# AWS (local only — IAM role used in production)
AWS_REGION=us-east-1
