{
    "name": "ecom-admin-backend",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
        "build": "tsc",
        "start": "node dist/index.js",
        "test": "jest --forceExit --detectOpenHandles",
        "seed:mock": "ts-node --require dotenv/config src/config/mockSeed.ts",
        "seed:mock:clean": "ts-node --require dotenv/config src/config/mockSeed.ts --clean",
        "seed:storefront": "ts-node --require dotenv/config src/config/seedStorefront.ts",
        "lint": "tsc --noEmit"
    },
    "dependencies": {
        "@aws-sdk/client-s3": "^3.700.0",
        "@aws-sdk/client-secrets-manager": "^3.700.0",
        "@aws-sdk/s3-request-presigner": "^3.700.0",
        "@hono/node-server": "^1.13.0",
        "bcrypt": "^5.1.1",
        "bullmq": "^5.30.0",
        "dayjs": "^1.11.13",
        "dayjs-plugin-utc": "^0.1.2",
        "dotenv": "^16.4.7",
        "hono": "^4.7.0",
        "ioredis": "^5.4.2",
        "jsonwebtoken": "^9.0.2",
        "mongoose": "^8.9.0",
        "razorpay": "^2.9.8",
        "resend": "^6.12.4",
        "stripe": "^17.5.0",
        "uuid": "^11.0.5",
        "zod": "^3.24.0"
    },
    "devDependencies": {
        "@faker-js/faker": "^10.4.0",
        "@types/bcrypt": "^5.0.2",
        "@types/jest": "^29.5.14",
        "@types/jsonwebtoken": "^9.0.7",
        "@types/node": "^22.10.0",
        "@types/supertest": "^6.0.2",
        "@types/uuid": "^10.0.0",
        "ioredis-mock": "^8.9.0",
        "jest": "^29.7.0",
        "mongodb-memory-server": "^10.4.0",
        "supertest": "^7.0.0",
        "ts-jest": "^29.2.0",
        "ts-node": "^10.9.2",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.7.0"
    }
}
